# =============================================================================
# Frontend environment variables (Vite).
#
# Vite only exposes vars prefixed with VITE_ to the client bundle.
# Copy this file to frontend/.env (gitignored) for local overrides, or set
# these in Vercel's "Environment Variables" panel for production builds.
# =============================================================================

# Absolute URL of the backend API (including the /api suffix).
#
# Local dev: leave unset or set to /api so the Vite proxy in vite.config.js
# forwards requests to http://localhost:8080.
#
# Production example:
#   VITE_API_BASE_URL=https://capmlab-backend.onrender.com/api
VITE_API_BASE_URL=/api
