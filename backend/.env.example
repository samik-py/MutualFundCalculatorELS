# =============================================================================
# Backend environment variables.
#
# Copy this file to backend/.env (gitignored) and fill in real values for
# local development. In production (Render), set these in the dashboard's
# "Environment" tab — never commit real secrets.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Render injects PORT automatically. Locally you can leave it unset (defaults to 8080).
# PORT=8080

# Comma-separated list of frontend origins allowed to call the API.
# Local dev: http://localhost:5173
# Production example: https://capmlab.vercel.app,https://capmlab.io
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── JWT auth ──────────────────────────────────────────────────────────────────
# MUST be at least 32 bytes (256 bits) for HS256.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# ── FRED (risk-free rate) ─────────────────────────────────────────────────────
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Falls back to capm.riskFreeFallback (0.04) if missing or rate limited.
FRED_API_KEY=

# ── Google Gemini (AI portfolio classifier + crypto insights) ─────────────────
# Get a key at https://aistudio.google.com/app/apikey
# Falls back to a keyword-based heuristic classifier if missing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Coinbase (crypto suite — optional) ────────────────────────────────────────
# Only needed if you want the live crypto features. The crypto pages will
# render with mock/upload data without these.
COINBASE_ACCESS_TOKEN=
COINBASE_OAUTH_CLIENT_ID=
COINBASE_OAUTH_REDIRECT_URI=http://localhost:5173/crypto
